include README.md
include LICENSE
include pyproject.toml

recursive-include config *.example.yaml
recursive-include deployment *.sh *.service
recursive-include docs *.md
recursive-include tests test_*.py

global-exclude *.py[cod]
global-exclude __pycache__
global-exclude .pytest_cache
global-exclude .ruff_cache

prune build
prune dist
prune .venv